    "custom": {
      "border-radius": {
        "0": "0px",
        "1": "16px",
        "2": "32px",
        "025": "4px",
        "05": "8px",
        "1-5": "24px",
        "rounded": "999px",
        "card": "var(--wp--custom--border-radius--1-5)"
      },
      "layout": {
				"gap": "2rem",
				"gap-small": "16px",
				"gap-large": "40px",
				"gap-x-large": "80px",
				"content": "1320px",
				"content-wide": "1512px",
				"padding": "16px"
			},
      "line-height": {
				"headings": 1.2,
				"normal": 1.5,
				"tiny": 1
			}
    },
    "layout": {
      "contentSize": "var(--wp--custom--layout--content)",
			"wideSize": "var(--wp--custom--layout--content-wide)"
    },
