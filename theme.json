    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "dropCap": false,
      "fontWeight": true,
      "letterSpacing": false,
      "lineHeight": true,
      "fontFamilies": [
        {
          "fontFace": [
            {
              "fontDisplay": "swap",
              "fontFamily": "Zalando Sans SemiExpanded",
              "fontStretch": "normal",
              "fontStyle": "normal",
              "fontWeight": "400 600 700",
              "src": [ "file:./assets/fonts/ZalandoSansSemiExpanded-VariableFont_wght.ttf" ]
            },
            {
              "fontDisplay": "swap",
              "fontFamily": "Zalando Sans SemiExpanded",
              "fontStretch": "normal",
              "fontStyle": "italic",
              "fontWeight": "400 600 700",
              "src": [ "file:./assets/fonts/ZalandoSansSemiExpanded-Italic-VariableFont_wght.ttf" ]
            }
          ],
          "fontFamily": "\"Zalando Sans SemiExpanded\", serif",
          "name": "Main Font",
          "slug": "font-main"
        },
        {
          "fontFace": [
            {
              "fontDisplay": "swap",
              "fontFamily": "Punoer",
              "fontStretch": "normal",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": [ "file:./assets/fonts/Punoer.otf" ]
            }
          ],
          "fontFamily": "\"Punoer\", sans-serif",
          "name": "Caption Font",
          "slug": "font-caption"
        }
