{
  "name": "sorribes",
  "version": "1.0.0",
  "description": "Theme WP _Sumun Hybrid para Sorribes",
  "repository": {
    "type": "git",
    "url": "https://github.com/SumunComunicacionGlobal/sorribes.git"
  },
  "keywords": [
    "sass",
    "wordpress",
    "woocommerce"
  ],
  "author": "Sumun.net",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SumunComunicacionGlobal/sorribes/issues"
  },
  "homepage": "https://github.com/SumunComunicacionGlobal/sorribes#readme",
  "devDependencies": {
    "@wordpress/scripts": "^31.7.0",
    "@wordpress/stylelint-config": "^23.33.0",
    "dir-archiver": "^2.2.0",
    "sass": "^1.98.0",
    "stylelint": "^16.9.0",
    "uglify-js": "^3.19.0"
  },
  "scripts": {
    "watch": "sass --watch sass:./ --no-source-map --style compressed",
    "compile:css": "sass sass:./ && stylelint '*.css' --fix || true && stylelint '*.css' --fix",
    "compile:js": "uglifyjs assets/js/*.js > assets/js/sorribes.min.js",
    "bundle": "dir-archiver --src . --dest ../sorribes.zip --exclude .DS_Store .stylelintrc.json .eslintrc .git .gitattributes .github .gitignore README.md composer.json composer.lock node_modules vendor package-lock.json package.json .travis.yml phpcs.xml.dist sass style.css.map yarn.lock",
    "sync": "browser-sync start --proxy 'https://sorribes.local/' --files ['**/*.php', '*.*']",
    "dev": "npm run watch & npm run sync"
  }
}
